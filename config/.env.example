# Copy to config/.env (see README). Do not commit real secrets.

# Telegram — https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Comma-separated channel usernames (without @)
TELEGRAM_CHANNELS=

# SQLite (default: ./data/investigation.db under project cwd)
DATABASE_URL=sqlite:///./data/investigation.db

# Local Ollama — run: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=120

# ChromaDB persistence (default: ./data/chroma relative to project)
# CHROMA_PERSIST_DIR=

# Optional: proxy for web search (ddgs). Example: socks5h://127.0.0.1:9150
# See https://pypi.org/project/ddgs/
# DDGS_PROXY=
